@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">⛳ GolfCoach</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <span aria-hidden="true">&#x1F3E0;</span> Feed
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/upload">
                        <span aria-hidden="true">&#x1F4F7;</span> Post
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <button class="nav-link btn btn-link" @onclick="HandleSignOut">
                        <span aria-hidden="true">&#x2192;</span> Sign Out
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">Sign In</NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/signup">Sign Up</NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            AuthService.AuthStateChanged += () => InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private async Task HandleSignOut()
    {
        await AuthService.SignOutAsync();
        Nav.NavigateTo("/login");
    }
}

